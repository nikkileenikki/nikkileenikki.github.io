{
  "id": "carousel-kult-v1",
  "name": "Carousel - KULT",
  "category": "carousel",
  "defaults": {
    "autoplay": true,
    "autoplay_delay": 1.5,
    "transition_duration": 0.5,
    "enable_swipe": true,
    "shuffle": false
  },
  "variables": [
    { "key": "cta_default", "type": "image", "required": true, "label": "CTA Default Image" },
    { "key": "cta_hover", "type": "image", "required": true, "label": "CTA Hover Image" },
    { "key": "arrow_asset", "type": "image", "required": true, "label": "Arrow Asset" },
    {
      "key": "slides",
      "type": "repeater",
      "required": true,
      "min": 1,
      "max": 4,
      "label": "Slides",
      "fields": [
        { "key": "image", "type": "image", "required": true, "label": "Slide Image" },
        { "key": "heading", "type": "text", "required": true, "label": "Heading" },
        { "key": "body", "type": "text", "required": true, "label": "Body" },
        { "key": "click_url", "type": "url", "required": true, "label": "Click URL" },
        { "key": "click_index", "type": "number", "required": true, "label": "Click Index" }
      ]
    }
  ],
  "sizes": {
    "300x250": {
      "label": "300x250",
      "width": 300,
      "height": 250,
      "layout": {
        "width": 300,
        "height": 250,
        "slide_width": 300,
        "slide_height": 250
      },
      "html": "sizes/300x250/template.html",
      "css": "sizes/300x250/template.css",
      "js": "sizes/300x250/template.js"
    }
  }
}
